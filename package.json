{
  "name": "tamtri",
  "version": "0.1.0",
  "private": true,
  "description": "Model-agnostic agent UI shell. Rust daemon + shared TypeScript surfaces (Electron desktop, web, Expo mobile).",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "build": "pnpm -r --if-present run build",
    "protocol:generate": "pnpm --filter @tamtri/protocol run generate",
    "daemon:build": "cargo build -p tamtri-daemon",
    "daemon:run": "cargo run -p tamtri-daemon",
    "app:web": "pnpm --filter @tamtri/app run web",
    "dev": "node scripts/dev.mjs",
    "dev:web": "node scripts/dev-web.mjs",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "dev:ios": "node scripts/dev-ios.mjs",
    "smoke:connection": "node scripts/connection-smoke.mjs",
    "desktop:dev": "TAMTRI_USE_DEV_SERVER=1 pnpm --filter @tamtri/desktop run start",
    "desktop:build": "pnpm --filter @tamtri/desktop run build"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-native": "0.81.5",
      "typescript": "5.9.3"
    }
  }
}
