{
  "expo": {
    "name": "tamtri",
    "slug": "tamtri",
    "scheme": "tamtri",
    "platforms": ["ios", "android", "web"],
    "userInterfaceStyle": "dark",
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ]
    ],
    "ios": {
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    }
  }
}
